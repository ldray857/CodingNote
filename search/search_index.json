e\u5b9e\u8df5  </li> <li>\u6587\u672c\u5206\u7c7b\u3001\u81ea\u7136\u8bed\u8a00\u5904\u7406\u5e94\u7528  </li> <li>\u63a8\u8350\u7cfb\u7edf\u4e0e\u6570\u636e\u9a71\u52a8\u5e94\u7528  </li> <li>\u67e5\u770b\u5de5\u7a0b\u5b9e\u8df5\u6848\u4f8b</li> </ul>"},{"location":"AI/#6","title":"6\ufe0f\u20e3 \u8d44\u6e90\u4e0e\u5b66\u4e60\u8d44\u6599 \ud83d\udcda","text":"<ul> <li>\u5b98\u65b9\u6587\u6863\uff1aTensorFlow, PyTorch, scikit-learn  </li> <li>\u5f00\u6e90\u9879\u76ee\u4e0e GitHub \u4ed3\u5e93\u63a8\u8350  </li> <li>\u5b66\u4e60\u8def\u7ebf\u4e0e\u4e66\u7c4d\u63a8\u8350  </li> <li>\u67e5\u770b\u8d44\u6e90\u4e0e\u5b66\u4e60\u8d44\u6599</li> </ul>"},{"location":"CS/","title":"\ud83d\udda5\ufe0f \u8ba1\u7b97\u673a\u4f7f\u7528\u7ecf\u9a8c","text":"<p>\u8fd9\u662f\u6211\u8bb0\u5f55\u7684 \u8ba1\u7b97\u673a\u4f7f\u7528\u7ecf\u9a8c\u4e0e\u6280\u5de7 \u603b\u89c8 \ud83d\udcc2\uff0c\u5305\u62ec\u65e5\u5e38\u529e\u516c\u3001\u5f00\u53d1\u73af\u5883\u3001\u5de5\u5177\u4f7f\u7528\u3001\u6548\u7387\u63d0\u5347\u548c\u5de5\u7a0b\u5b9e\u8df5\u5fc3\u5f97\u3002\u6bcf\u4e2a\u5c0f\u8282\u90fd\u5e26\u6709\u5bfc\u822a\uff0c\u65b9\u4fbf\u5feb\u901f\u8df3\u8f6c\u3002</p>"},{"location":"CS/#_2","title":"\ud83d\udcd1 \u76ee\u5f55","text":"<ul> <li>1\ufe0f\u20e3 \u7cfb\u7edf\u73af\u5883\u4e0e\u914d\u7f6e</li> <li>2\ufe0f\u20e3 \u7f16\u8f91\u5668\u4e0e\u5f00\u53d1\u73af\u5883</li> <li>3\ufe0f\u20e3 \u547d\u4ee4\u884c\u4e0e\u7ec8\u7aef\u6280\u5de7</li> <li>4\ufe0f\u20e3 \u7f51\u7edc\u4e0e\u5b89\u5168</li> <li>5\ufe0f\u20e3 \u81ea\u52a8\u5316\u4e0e\u811a\u672c</li> <li>6\ufe0f\u20e3 \u5de5\u5177\u4f7f\u7528\u5fc3\u5f97</li> <li>7\ufe0f\u20e3 \u5e38\u89c1\u95ee\u9898\u4e0e\u6392\u67e5\u7ecf\u9a8c</li> </ul>"},{"location":"CS/#1","title":"1\ufe0f\u20e3 \u7cfb\u7edf\u73af\u5883\u4e0e\u914d\u7f6e \ud83d\udee0\ufe0f","text":"<ul> <li>\u64cd\u4f5c\u7cfb\u7edf\u9009\u62e9\u4e0e\u4f18\u5316\uff08Windows / macOS / Linux\uff09  </li> <li>\u7cfb\u7edf\u73af\u5883\u53d8\u91cf\u8bbe\u7f6e\u4e0e PATH \u914d\u7f6e  </li> <li>\u8f6f\u4ef6\u5305\u7ba1\u7406\u4e0e\u7248\u672c\u63a7\u5236\u6280\u5de7  </li> <li>\u67e5\u770b\u7cfb\u7edf\u73af\u5883\u7ecf\u9a8c</li> </ul>"},{"location":"CS/#2","title":"2\ufe0f\u20e3 \u7f16\u8f91\u5668\u4e0e\u5f00\u53d1\u73af\u5883 \ud83d\udd8a\ufe0f","text":"<ul> <li>VS Code\u3001Visual Studio\u3001CLion \u7b49 IDE \u914d\u7f6e  </li> <li>\u63d2\u4ef6/\u6269\u5c55\u5b89\u88c5\u4e0e\u8c03\u4f18  </li> <li>\u5feb\u6377\u952e\u4e0e\u9ad8\u6548\u5f00\u53d1\u6280\u5de7  </li> <li>\u67e5\u770b\u7f16\u8f91\u5668\u7ecf\u9a8c</li> </ul>"},{"location":"CS/#3","title":"3\ufe0f\u20e3 \u547d\u4ee4\u884c\u4e0e\u7ec8\u7aef\u6280\u5de7 \ud83d\udcbb","text":"<ul> <li>Shell \u57fa\u7840\u547d\u4ee4\uff08bash / zsh / PowerShell\uff09  </li> <li>\u9ad8\u6548\u76ee\u5f55\u5bfc\u822a\u3001\u6587\u4ef6\u64cd\u4f5c\u3001\u6279\u91cf\u5904\u7406  </li> <li>\u811a\u672c\u4e0e\u547d\u4ee4\u522b\u540d\u6280\u5de7  </li> <li>\u67e5\u770b\u547d\u4ee4\u884c\u7ecf\u9a8c</li> </ul>"},{"location":"CS/#4","title":"4\ufe0f\u20e3 \u7f51\u7edc\u4e0e\u5b89\u5168 \ud83d\udd12","text":"<ul> <li>\u7f51\u7edc\u8c03\u8bd5\u4e0e\u6293\u5305\u5de5\u5177\u4f7f\u7528  </li> <li>\u9632\u706b\u5899\u3001\u4ee3\u7406\u4e0e VPN \u914d\u7f6e\u7ecf\u9a8c  </li> <li>\u5b89\u5168\u9632\u62a4\u4e0e\u8d26\u53f7\u7ba1\u7406\u6700\u4f73\u5b9e\u8df5  </li> <li>\u67e5\u770b\u7f51\u7edc\u5b89\u5168\u7ecf\u9a8c</li> </ul>"},{"location":"CS/#5","title":"5\ufe0f\u20e3 \u81ea\u52a8\u5316\u4e0e\u811a\u672c \ud83e\udd16","text":"<ul> <li>\u6279\u5904\u7406\u3001Python \u811a\u672c\u3001PowerShell \u811a\u672c  </li> <li>\u65e5\u5e38\u4efb\u52a1\u81ea\u52a8\u5316\u3001\u6570\u636e\u5904\u7406\u548c\u6587\u4ef6\u7ba1\u7406  </li> <li>\u5b9a\u65f6\u4efb\u52a1\u4e0e\u81ea\u52a8\u5907\u4efd\u5b9e\u8df5  </li> <li>\u67e5\u770b\u81ea\u52a8\u5316\u7ecf\u9a8c</li> </ul>"},{"location":"CS/#6","title":"6\ufe0f\u20e3 \u5de5\u5177\u4f7f\u7528\u5fc3\u5f97 \ud83d\udee0\ufe0f","text":"<ul> <li>Git / GitHub \u9ad8\u6548\u4f7f\u7528\u6280\u5de7  </li> <li>Docker\u3001\u865a\u62df\u673a\u4e0e\u5bb9\u5668\u5316\u5b9e\u8df5  </li> <li>\u5e38\u7528\u5f00\u53d1\u3001\u8c03\u8bd5\u548c\u6d4b\u8bd5\u5de5\u5177\u5fc3\u5f97  </li> <li>\u67e5\u770b\u5de5\u5177\u7ecf\u9a8c</li> </ul>"},{"location":"CS/#7","title":"7\ufe0f\u20e3 \u5e38\u89c1\u95ee\u9898\u4e0e\u6392\u67e5\u7ecf\u9a8c \ud83d\udd0d","text":"<ul> <li>\u7cfb\u7edf\u5d29\u6e83\u3001\u8f6f\u4ef6\u51b2\u7a81\u4e0e\u62a5\u9519\u89e3\u51b3\u7ecf\u9a8c  </li> <li>\u8c03\u8bd5\u601d\u8def\u3001\u65e5\u5fd7\u5206\u6790\u3001\u9519\u8bef\u6392\u67e5\u65b9\u6cd5  </li> <li>\u5b9e\u6218\u6848\u4f8b\u5206\u4eab  </li> <li>\u67e5\u770b\u6392\u67e5\u7ecf\u9a8c</li> </ul>"},{"location":"GIS/","title":"\ud83c\udf0d GIS\u5de5\u7a0b\u5f00\u53d1\u5e94\u7528","text":"<p>\u6b22\u8fce\u6765\u5230\u6211\u7684 GIS \u77e5\u8bc6\u4e0e\u5de5\u5177\u7b14\u8bb0 \ud83d\uddfa\ufe0f\u3002\u672c\u677f\u5757\u7cfb\u7edf\u6574\u7406\u4e86\u5730\u7406\u4fe1\u606f\u7cfb\u7edf\uff08GIS\uff09\u76f8\u5173\u7684\u6982\u5ff5\u3001\u8f6f\u4ef6\u5de5\u5177\u3001\u5f00\u53d1\u73af\u5883\u53ca\u7f16\u7a0b\u5b9e\u8df5\uff0c\u6db5\u76d6\u4ece\u57fa\u7840\u7406\u8bba\u5230\u5b9e\u6218\u64cd\u4f5c\u7684\u5168\u6d41\u7a0b\uff0c\u9002\u5408\u5b66\u4e60\u548c\u5de5\u7a0b\u5e94\u7528\u53c2\u8003\u3002  </p>"},{"location":"GIS/#_1","title":"\ud83d\udcd1 \u76ee\u5f55","text":"<p>\uff08\u70b9\u51fb\u4e0b\u65b9\u53ef\u4ee5\u76f4\u63a5\u8df3\u8f6c\uff09   - [\ud83c\udf0d GIS \u677f\u5757 Index]   - [1\ufe0f\u20e3 GIS \u7cfb\u7edf\u6982\u89c8   - [2\ufe0f\u20e3 ArcGIS Pro]   - [3\ufe0f\u20e3 QGIS]   - [4\ufe0f\u20e3 VS Code \u4e0e GIS \u5f00\u53d1]   - [5\ufe0f\u20e3 Python \u4e0e GIS]   - [6\ufe0f\u20e3 \ud83d\udcda \u53c2\u8003\u8d44\u6599\u4e0e\u6269\u5c55]</p> <p></p>"},{"location":"GIS/#1-gis","title":"1\ufe0f\u20e3 GIS \u7cfb\u7edf\u6982\u89c8","text":"<ul> <li>\ud83d\udccc \u4ec0\u4e48\u662f GIS\uff1a\u5730\u7406\u4fe1\u606f\u7cfb\u7edf\u7684\u5b9a\u4e49\u4e0e\u57fa\u672c\u6982\u5ff5  </li> <li>\ud83c\udf10 \u6838\u5fc3\u529f\u80fd\uff1a\u6570\u636e\u91c7\u96c6\u3001\u5b58\u50a8\u3001\u7ba1\u7406\u3001\u5206\u6790\u4e0e\u53ef\u89c6\u5316  </li> <li>\ud83d\uddc2\ufe0f \u7a7a\u95f4\u6570\u636e\u7c7b\u578b\uff1a  </li> <li>\u77e2\u91cf\u6570\u636e\uff08\u70b9\u3001\u7ebf\u3001\u9762\uff09  </li> <li>\u6805\u683c\u6570\u636e\uff08\u9065\u611f\u5f71\u50cf\u3001\u6570\u5b57\u9ad8\u7a0b\u6a21\u578b\uff09  </li> <li>\u5c5e\u6027\u6570\u636e\uff08\u4e0e\u7a7a\u95f4\u8981\u7d20\u76f8\u5173\u7684\u8868\u683c\u4fe1\u606f\uff09  </li> <li>\ud83d\udd04 GIS \u6570\u636e\u5904\u7406\u6d41\u7a0b\uff1a\u6570\u636e\u91c7\u96c6 \u2192 \u6570\u636e\u7ba1\u7406 \u2192 \u7a7a\u95f4\u5206\u6790 \u2192 \u5730\u56fe\u53ef\u89c6\u5316  </li> </ul>"},{"location":"GIS/#2-arcgis-pro","title":"2\ufe0f\u20e3 ArcGIS Pro","text":"<ul> <li>\ud83d\udcbb ArcGIS Pro \u7b80\u4ecb\uff1aESRI \u65d7\u8230 GIS \u8f6f\u4ef6\uff0c\u652f\u6301\u684c\u9762\u5236\u56fe\u3001\u5206\u6790\u4e0e\u4e09\u7ef4\u5efa\u6a21  </li> <li>\u2699\ufe0f \u6838\u5fc3\u529f\u80fd\u6a21\u5757\uff1a  </li> <li>\u5730\u56fe\u5236\u56fe\u4e0e\u53ef\u89c6\u5316  </li> <li>\u7a7a\u95f4\u5206\u6790\u4e0e\u5730\u7406\u5904\u7406\u5de5\u5177  </li> <li>\u4e09\u7ef4\u573a\u666f\u4e0e\u5f71\u50cf\u5206\u6790  </li> <li>\ud83d\uddc4\ufe0f \u9879\u76ee\u4e0e\u5de5\u4f5c\u7a7a\u95f4\u7ba1\u7406\uff1a\u5730\u56fe\u6587\u6863\u3001\u5730\u7406\u6570\u636e\u5e93\u3001\u56fe\u5c42\u7ba1\u7406  </li> <li>\ud83d\udc0d ArcPy \u81ea\u52a8\u5316\uff1a\u5229\u7528 Python \u811a\u672c\u8fdb\u884c\u6570\u636e\u5904\u7406\u3001\u6279\u91cf\u5206\u6790\u548c\u5730\u56fe\u8f93\u51fa  </li> <li>\ud83d\udcdd \u5b9e\u6218\u793a\u4f8b\uff1a\u6279\u91cf\u751f\u6210\u5730\u56fe\u3001\u81ea\u52a8\u5316\u6570\u636e\u6e05\u7406\u3001\u7a7a\u95f4\u5206\u6790\u4efb\u52a1  </li> </ul>"},{"location":"GIS/#3-qgis","title":"3\ufe0f\u20e3 QGIS","text":"<ul> <li>\ud83d\udca1 QGIS \u7b80\u4ecb\uff1a\u5f00\u6e90\u3001\u8de8\u5e73\u53f0 GIS \u8f6f\u4ef6\uff0c\u652f\u6301\u591a\u79cd\u63d2\u4ef6\u62d3\u5c55  </li> <li>\ud83d\udd0c \u5e38\u7528\u63d2\u4ef6\u4e0e\u529f\u80fd\u62d3\u5c55\uff1a\u5730\u7406\u7f16\u7801\u3001\u7f51\u7edc\u5206\u6790\u30013D \u53ef\u89c6\u5316\u7b49  </li> <li>\ud83d\uddfa\ufe0f \u77e2\u91cf\u4e0e\u6805\u683c\u6570\u636e\u5904\u7406\uff1a\u6570\u636e\u8f6c\u6362\u3001\u6295\u5f71\u7ba1\u7406\u3001\u7a7a\u95f4\u5206\u6790  </li> <li>\ud83d\udc0d PyQGIS \u7f16\u7a0b\uff1aPython API \u5b9e\u73b0 QGIS \u81ea\u52a8\u5316\u64cd\u4f5c\u548c\u81ea\u5b9a\u4e49\u5de5\u5177  </li> <li>\ud83d\udcca \u5b9e\u6218\u793a\u4f8b\uff1a\u6279\u91cf\u5730\u56fe\u6e32\u67d3\u3001\u7a7a\u95f4\u5206\u6790\u5de5\u4f5c\u6d41\u81ea\u52a8\u5316  </li> </ul>"},{"location":"GIS/#4-vs-code-gis","title":"4\ufe0f\u20e3 VS Code \u4e0e GIS \u5f00\u53d1","text":"<ul> <li>\ud83d\udda5\ufe0f \u5f00\u53d1\u73af\u5883\u914d\u7f6e\uff1aVS Code + Python + GIS \u5e93  </li> <li>\ud83d\udd27 Python\u3001ArcPy \u4e0e PyQGIS \u96c6\u6210\uff1a\u5728 VS Code \u4e2d\u8fdb\u884c\u811a\u672c\u5f00\u53d1\u548c\u8c03\u8bd5  </li> <li>\ud83d\udc1e \u8c03\u8bd5\u4e0e\u7248\u672c\u63a7\u5236\uff1a\u5229\u7528 Git \u7ba1\u7406 GIS \u9879\u76ee\u7248\u672c\uff0c\u652f\u6301\u591a\u4eba\u534f\u4f5c  </li> <li>\u26a1 \u5b9e\u6218\u793a\u4f8b\uff1a\u5728 VS Code \u4e2d\u6279\u91cf\u5904\u7406 shapefile\u3001\u751f\u6210\u5730\u56fe\u62a5\u544a\u3001\u81ea\u52a8\u5316\u6570\u636e\u5206\u6790  </li> </ul>"},{"location":"GIS/#5-python-gis","title":"5\ufe0f\u20e3 Python \u4e0e GIS","text":"<ul> <li>\ud83d\udc0d Python \u5728 GIS \u7684\u6838\u5fc3\u4f5c\u7528\uff1a\u6570\u636e\u5904\u7406\u3001\u5206\u6790\u3001\u53ef\u89c6\u5316\u4e0e\u81ea\u52a8\u5316  </li> <li>\ud83d\udce6 \u5e38\u7528 Python \u5e93\uff1a  </li> <li>GeoPandas\uff1a\u7a7a\u95f4\u6570\u636e\u5206\u6790\u4e0e\u64cd\u4f5c  </li> <li>Shapely\uff1a\u51e0\u4f55\u5bf9\u8c61\u64cd\u4f5c  </li> <li>Fiona\uff1a\u8bfb\u5199\u5730\u7406\u6570\u636e\u6587\u4ef6  </li> <li>Rasterio\uff1a\u6805\u683c\u6570\u636e\u5904\u7406  </li> <li>Matplotlib / Folium\uff1a\u7a7a\u95f4\u53ef\u89c6\u5316  </li> <li>\ud83d\udd04 \u7a7a\u95f4\u5206\u6790\u4e0e\u53ef\u89c6\u5316\u793a\u4f8b\uff1a\u7f13\u51b2\u533a\u5206\u6790\u3001\u53e0\u7f6e\u5206\u6790\u3001\u70ed\u529b\u56fe\u3001\u4ea4\u4e92\u5f0f Web \u5730\u56fe  </li> <li>\ud83d\udcdd \u9879\u76ee\u5b9e\u6218\uff1a\u81ea\u52a8\u5316\u6279\u91cf\u5730\u56fe\u751f\u6210\u3001\u7a7a\u95f4\u6570\u636e\u6e05\u6d17\u4e0e\u7edf\u8ba1\u5206\u6790  </li> </ul>"},{"location":"GIS/#6","title":"6\ufe0f\u20e3 \ud83d\udcda \u53c2\u8003\u8d44\u6599\u4e0e\u6269\u5c55","text":"<ul> <li>\ud83c\udf10 \u5b98\u65b9\u6587\u6863\u4e0e\u6559\u7a0b\u94fe\u63a5\uff08ESRI\u3001QGIS\u3001Python GIS \u5e93\uff09  </li> <li>\ud83d\udcd6 \u63a8\u8350\u4e66\u7c4d\u4e0e\u5b66\u4e60\u8def\u7ebf  </li> <li>\ud83d\udcac GIS \u793e\u533a\u4e0e\u5f00\u6e90\u9879\u76ee\uff08GIS Stack Exchange\u3001GitHub \u4ed3\u5e93\uff09  </li> </ul>"},{"location":"c_cpp/","title":"\ud83d\udcbb C &amp; C++","text":"<p>\u5173\u4e8e C \u548c C++ \u7684\u5de5\u5177\u3001\u73af\u5883\u914d\u7f6e\u3001\u4ee3\u7801\u89c4\u8303\u548c\u6ce8\u610f\u4e8b\u9879\uff0c\u6211\u4f1a\u5728\u8fd9\u91cc\u7cfb\u7edf\u8bb0\u5f55\uff0c\u65b9\u4fbf\u5feb\u901f\u53c2\u8003\uff0c\u540c\u65f6\u4e5f\u4f1a\u52a0\u5165\u4e00\u4e9b\u5bb9\u6613\u51fa\u9519\u7684\u70b9 \u26a0\ufe0f\u3002  </p>"},{"location":"c_cpp/#1","title":"1\ufe0f\u20e3 \u5173\u4e8e\u5b66\u4e60\u987a\u5e8f\u4e0e\u8bed\u8a00\u5b9a\u4f4d","text":"<p>\u6bcf\u4e00\u7ae0\u7f16\u7a0b\u8bed\u8a00\u7684\u5f00\u5934\uff0c\u6211\u603b\u4f1a\u4ecb\u7ecd\u8fd9\u4e2a\u8bdd\u9898\u3002\u9996\u5148\u660e\u786e\u4e00\u70b9\uff1a\u6309\u7167\u62bd\u8c61\u7a0b\u5ea6\uff0c\u7f16\u7a0b\u8bed\u8a00\u53ef\u4ee5\u5206\u4e3a \u4f4e\u7ea7\u8bed\u8a00 \u548c \u9ad8\u7ea7\u8bed\u8a00\u3002</p>"},{"location":"c_cpp/#1-low-level-language","title":"1. \u4f4e\u7ea7\u8bed\u8a00 (Low-level Language) \ud83d\udee0\ufe0f","text":"<ul> <li>\u673a\u5668\u8bed\u8a00\uff1a\u4e8c\u8fdb\u5236\u4ee3\u7801\uff080 \u548c 1\uff09\uff0c\u76f4\u63a5\u7531 CPU \u6267\u884c \u3002  </li> <li>\u6c47\u7f16\u8bed\u8a00\uff1a\u4f7f\u7528\u52a9\u8bb0\u7b26\u4ee3\u66ff\u673a\u5668\u6307\u4ee4\uff0c\u4e0e\u5e95\u5c42\u786c\u4ef6\u9ad8\u5ea6\u6302\u94a9\uff0c\u5e38\u7528\u4e8e\u9a71\u52a8\u5f00\u53d1\u548c\u5d4c\u5165\u5f0f\u5f00\u53d1 \u3002  </li> </ul>"},{"location":"c_cpp/#2-high-level-language","title":"2. \u9ad8\u7ea7\u8bed\u8a00 (High-level Language) \ud83d\ude80","text":"<p>\u4ee3\u8868\u8bed\u8a00\u5f88\u591a\uff0c\u5305\u62ec\uff1aC, C++, Java, Python, JavaScript\u3002 \u8fd9\u4e9b\u8bed\u8a00\u5c4f\u853d\u4e86\u786c\u4ef6\u7ec6\u8282\uff0c\u8bed\u6cd5\u66f4\u63a5\u8fd1\u81ea\u7136\u8bed\u8a00 \u3002  </p> <p>\u6ce8\uff1aC \u8bed\u8a00\u5e38\u88ab\u79f0\u4e3a\u201c\u4e2d\u7ea7\u8bed\u8a00\u201d\uff0c\u56e0\u4e3a\u5b83\u65e2\u6709\u9ad8\u7ea7\u8bed\u8a00\u7684\u7279\u6027\uff0c\u4e5f\u80fd\u76f4\u63a5\u64cd\u4f5c\u5185\u5b58\u6307\u9488 \u3002  </p> <p>\u6309\u7167\u53d1\u5c55\u7684\u987a\u5e8f\uff0c\u7f16\u7a0b\u8bed\u8a00\u662f\u4ece\u4f4e\u7ea7\u8bed\u8a00\u9010\u6b65\u6f14\u8fdb\u5230\u9ad8\u7ea7\u8bed\u8a00\u7684\uff0c\u6211\u4eec\u751a\u81f3\u53ef\u4ee5\u628a \"\u6c47\u7f16 \u2192 C \u8bed\u8a00 \u2192 C++ \u2192 Python\" \u770b\u6210\u4e00\u6761\u5b8c\u6574\u7684\u53d1\u5c55\u94fe\u6761 \ud83d\udd17\u3002</p> <p>\u90a3\u4e48\uff0c\u6211\u4eec\u662f\u5426\u8981\u4e25\u683c\u6309\u7167\u53d1\u5c55\u987a\u5e8f\u5b66\u4e60\u5462\uff1f\u663e\u7136\u4e0d\u592a\u5408\u7406\u3002\u6839\u636e\u6211\u7684\u7ecf\u9a8c\uff0c\u6700\u4f18\u5b66\u4e60\u987a\u5e8f\u662f\uff1a  </p> <p>C \u8bed\u8a00 \u2192 \u6c47\u7f16 \u2192 C++ \u2192 Python </p> <p>\u56e0\u4e3a\u5728\u6ca1\u6709 C \u8bed\u8a00\u57fa\u7840\u65f6\uff0c\u6c47\u7f16\u8bed\u8a00\u662f\u96be\u4ee5\u7406\u89e3\u7684\uff1b\u800cPython \u53ef\u4ee5\u770b\u4f5c\u662f C++ \u7684\u7b80\u5316\u7248\u672c \ud83d\udc0d\uff0c\u597d\u6bd4\u6570\u5b66\u4e2d\u7684\u4e8c\u7ea7\u7ed3\u8bba\uff0c\u56e0\u6b64\u5e94\u653e\u5728\u6700\u540e\u5b66\u4e60\u3002 \u800c\u5982\u679c\u4f60\u4e3b\u52a8\u6765\u5148\u5b66\u4e60C\u8bed\u8a00\uff0c\u90a3\u4e48\u4f60\u7684\u5b66\u4e60\u987a\u5e8f\u663e\u7136\u662f\u76f8\u5f53\u6b63\u786e\u7684\u3002</p> <p></p>"},{"location":"c_cpp/#3-cc","title":"3. \u5173\u4e8eC\u548cC++","text":"<p>C \u548c C++ \u90fd\u5c5e\u4e8e \u9ad8\u7ea7\u8bed\u8a00\uff0c\u4f46\u76f8\u5bf9 Python \u66f4\u63a5\u8fd1\u5e95\u5c42\u786c\u4ef6 \u3002 - C \u8bed\u8a00\uff1a\u7ed3\u6784\u5316\u7f16\u7a0b\uff0c\u63a5\u8fd1\u7cfb\u7edf\u5e95\u5c42\uff0c\u9002\u5408\u7406\u89e3\u8ba1\u7b97\u673a\u539f\u7406\u548c\u5185\u5b58\u7ba1\u7406   </p> <ul> <li>C++ \u8bed\u8a00\uff1a\u5728 C \u7684\u57fa\u7840\u4e0a\u589e\u52a0\u9762\u5411\u5bf9\u8c61\u3001\u6a21\u677f\u548c STL \u7b49\u9ad8\u7ea7\u7279\u6027 </li> </ul> <p>\u5b66\u4e60\u5efa\u8bae\u987a\u5e8f\uff1aC \u2192 C++ \u7406\u7531\uff1aC \u662f\u57fa\u7840\uff0c\u638c\u63e1\u4e86\u5185\u5b58\u7ba1\u7406\u548c\u6307\u9488\u540e\uff0c\u518d\u5b66\u4e60 C++ \u7684\u7c7b\u548c\u6cdb\u578b\u7f16\u7a0b\u66f4\u5bb9\u6613\u7406\u89e3 \ud83e\udde9\u3002  </p>"},{"location":"c_cpp/#2","title":"2\ufe0f\u20e3 \u4e3a\u4ec0\u4e48\u5173\u6ce8\u5de5\u5177\u4e0e\u914d\u7f6e \ud83d\udee0\ufe0f","text":"<p>\u5f88\u591a\u540c\u5b66\u89c9\u5f97 C/C++ \u5b66\u4e60\u5c31\u662f\u5199\u4ee3\u7801\uff0c\u5176\u5b9e \u5de5\u5177\u548c\u73af\u5883\u914d\u7f6e \u5bf9\u5f00\u53d1\u6548\u7387\u548c\u7a0b\u5e8f\u7a33\u5b9a\u6027\u81f3\u5173\u91cd\u8981\uff1a  </p> <ul> <li>\u7f16\u8bd1\u5668\uff1aGCC\u3001Clang\u3001MSVC \ud83d\udda5\ufe0f  </li> <li>IDE/\u7f16\u8f91\u5668\uff1aVisual Studio\u3001CLion\u3001VS Code  </li> <li>\u6784\u5efa\u5de5\u5177\uff1aMake\u3001CMake  </li> <li>\u8c03\u8bd5\u5de5\u5177\uff1aGDB\u3001LLDB\u3001Visual Studio \u8c03\u8bd5\u5668  </li> <li>\u7248\u672c\u63a7\u5236\uff1aGit\uff0c\u786e\u4fdd\u56e2\u961f\u534f\u4f5c\u548c\u4ee3\u7801\u7ba1\u7406\u987a\u7545  </li> </ul> <p>\u914d\u7f6e\u4e0d\u5f53\u5bb9\u6613\u51fa\u73b0\u7f16\u8bd1\u9519\u8bef\u3001\u94fe\u63a5\u5931\u8d25\u6216\u8c03\u8bd5\u56f0\u96be \ud83d\udd27\u3002  </p>"},{"location":"c_cpp/#3","title":"3\ufe0f\u20e3 \u4ee3\u7801\u89c4\u8303\u4e0e\u98ce\u683c \ud83d\udcdd","text":"<p>\u826f\u597d\u7684 C/C++ \u4ee3\u7801\u89c4\u8303\u53ef\u4ee5\u63d0\u9ad8\u53ef\u8bfb\u6027\u3001\u53ef\u7ef4\u62a4\u6027\uff0c\u4e5f\u65b9\u4fbf\u56e2\u961f\u534f\u4f5c\uff1a  </p> <ul> <li>\u547d\u540d\u89c4\u8303\uff1a\u53d8\u91cf\u540d\u3001\u51fd\u6570\u540d\u3001\u7c7b\u540d\u7edf\u4e00\u98ce\u683c  </li> <li>\u7f29\u8fdb\u4e0e\u7a7a\u683c\uff1a\u901a\u5e38\u4f7f\u7528 4 \u7a7a\u683c\u7f29\u8fdb  </li> <li>\u6ce8\u91ca\uff1a\u5173\u952e\u903b\u8f91\u5fc5\u987b\u6ce8\u91ca\u6e05\u695a\uff0c\u590d\u6742\u7b97\u6cd5\u53ef\u9644\u6d41\u7a0b\u8bf4\u660e  </li> <li>\u5934\u6587\u4ef6\u7ba1\u7406\uff1a\u5408\u7406\u4f7f\u7528 <code>#include</code> \u548c\u524d\u7f6e\u58f0\u660e\uff0c\u907f\u514d\u91cd\u590d\u5305\u542b  </li> <li>STL \u5bb9\u5668\u548c RAII\uff1a\u63a8\u8350\u4f7f\u7528\u6807\u51c6\u5e93\u5bb9\u5668\u7ba1\u7406\u8d44\u6e90\uff0c\u51cf\u5c11\u5185\u5b58\u6cc4\u6f0f\u98ce\u9669 \ud83d\udca1  </li> </ul>"},{"location":"c_cpp/#4","title":"4\ufe0f\u20e3 \u5e38\u89c1\u6ce8\u610f\u4e8b\u9879 \u26a0\ufe0f","text":"<ul> <li>\u6307\u9488\u4e0e\u5185\u5b58\u7ba1\u7406\uff1a\u907f\u514d\u91ce\u6307\u9488\u3001\u91cd\u590d\u91ca\u653e\u3001\u5185\u5b58\u6cc4\u6f0f \ud83d\udca5  </li> <li>\u7c7b\u578b\u8f6c\u6362\uff1aC++ \u5c3d\u91cf\u4f7f\u7528 <code>static_cast</code>\u3001<code>dynamic_cast</code>\uff0c\u51cf\u5c11\u9690\u5f0f\u8f6c\u6362\u98ce\u9669  </li> <li>\u5934\u6587\u4ef6\u5faa\u73af\u4f9d\u8d56\uff1a\u901a\u8fc7\u524d\u7f6e\u58f0\u660e\u89e3\u51b3  </li> <li>\u7f16\u8bd1\u5668\u8b66\u544a\uff1a\u5c3d\u91cf\u6d88\u9664\u6240\u6709\u8b66\u544a\uff0c\u517b\u6210\u597d\u4e60\u60ef  </li> <li>\u591a\u5e73\u53f0\u517c\u5bb9\u6027\uff1a\u6ce8\u610f\u4e0d\u540c\u7f16\u8bd1\u5668\u5bf9\u6807\u51c6\u7684\u5b9e\u73b0\u5dee\u5f02 \ud83c\udf10  </li> </ul>"},{"location":"c_cpp/#5","title":"5\ufe0f\u20e3 \u5c0f\u6280\u5de7\u4e0e\u5b9e\u7528\u5efa\u8bae \ud83d\udca1","text":"<ul> <li>\u4f7f\u7528 CMake \u7ba1\u7406\u8de8\u5e73\u53f0\u9879\u76ee  </li> <li>IDE \u914d\u7f6e\u81ea\u52a8\u683c\u5f0f\u5316\uff0c\u4fdd\u6301\u7edf\u4e00\u98ce\u683c  </li> <li>\u5e38\u7528\u8c03\u8bd5\u5b8f\u4e0e\u65e5\u5fd7\uff1a\u4f8b\u5982 <code>#define DEBUG_PRINT(...)</code> </li> <li>\u5355\u5143\u6d4b\u8bd5\u5de5\u5177\uff1aGoogle Test, Catch2  </li> <li>\u9605\u8bfb\u4f18\u79c0\u5f00\u6e90\u9879\u76ee\uff0c\u5b66\u4e60 C/C++ \u5de5\u7a0b\u5b9e\u8df5 \ud83c\udfd7\ufe0f  </li> </ul>"},{"location":"c_cpp/#6","title":"6\ufe0f\u20e3 \ud83d\udcda \u53c2\u8003\u8d44\u6599\u4e0e\u6269\u5c55","text":"<ul> <li>\u5b98\u65b9\u6587\u6863\u4e0e\u6807\u51c6\uff1aISO C, ISO C++  </li> <li>\u63a8\u8350\u4e66\u7c4d\uff1a  </li> <li>\u300aC\u7a0b\u5e8f\u8bbe\u8ba1\u8bed\u8a00\u300b by K&amp;R  </li> <li>\u300aEffective C++\u300b by Scott Meyers  </li> <li>\u300aC++ Primer\u300b by Lippman  </li> <li>\u793e\u533a\u4e0e\u5f00\u6e90\u8d44\u6e90\uff1aStack Overflow, cppreference.com, GitHub  </li> </ul>"},{"location":"python/","title":"\ud83d\udc0dPython","text":"<p>\u5173\u4e8e Python \u7684\u5404\u79cd\u6559\u7a0b\uff0c\u6211\u76f8\u4fe1\u5927\u5bb6\u90fd\u6709\u6216\u591a\u6216\u5c11\u7684\u5408\u9002\u9009\u62e9\u3002\u8fd9\u91cc\u6211\u4e3b\u8981\u8bb0\u5f55 Python \u7684\u7248\u672c\u4e0e\u914d\u7f6e\u95ee\u9898\uff0c\u4ee5\u53ca\u4e00\u4e9b\u5bb9\u6613\u51fa\u9519\u7684\u70b9 \ud83d\udca1\uff0c\u65b9\u4fbf\u5feb\u901f\u53c2\u8003\u3002</p>"},{"location":"python/#1","title":"1\ufe0f\u20e3 \u5173\u4e8e\u7f16\u7a0b\u8bed\u8a00\u7684\u5b66\u4e60\u987a\u5e8f","text":"<p>\u6bcf\u4e00\u7ae0\u7f16\u7a0b\u8bed\u8a00\u7684\u5f00\u5934\uff0c\u6211\u603b\u4f1a\u4ecb\u7ecd\u8fd9\u4e2a\u8bdd\u9898\u3002\u9996\u5148\u660e\u786e\u4e00\u70b9\uff1a\u6309\u7167\u62bd\u8c61\u7a0b\u5ea6\uff0c\u7f16\u7a0b\u8bed\u8a00\u53ef\u4ee5\u5206\u4e3a \u4f4e\u7ea7\u8bed\u8a00 \u548c \u9ad8\u7ea7\u8bed\u8a00\u3002</p>"},{"location":"python/#1-low-level-language","title":"1. \u4f4e\u7ea7\u8bed\u8a00 (Low-level Language) \ud83d\udee0\ufe0f","text":"<ul> <li>\u673a\u5668\u8bed\u8a00\uff1a\u4e8c\u8fdb\u5236\u4ee3\u7801\uff080 \u548c 1\uff09\uff0c\u76f4\u63a5\u7531 CPU \u6267\u884c \u3002  </li> <li>\u6c47\u7f16\u8bed\u8a00\uff1a\u4f7f\u7528\u52a9\u8bb0\u7b26\u4ee3\u66ff\u673a\u5668\u6307\u4ee4\uff0c\u4e0e\u5e95\u5c42\u786c\u4ef6\u9ad8\u5ea6\u6302\u94a9\uff0c\u5e38\u7528\u4e8e\u9a71\u52a8\u5f00\u53d1\u548c\u5d4c\u5165\u5f0f\u5f00\u53d1 \u3002</li> </ul>"},{"location":"python/#2-high-level-language","title":"2. \u9ad8\u7ea7\u8bed\u8a00 (High-level Language) \ud83d\ude80","text":"<p>\u4ee3\u8868\u8bed\u8a00\u5f88\u591a\uff0c\u5305\u62ec\uff1aC, C++, Java, Python, JavaScript\u3002 \u8fd9\u4e9b\u8bed\u8a00\u5c4f\u853d\u4e86\u786c\u4ef6\u7ec6\u8282\uff0c\u8bed\u6cd5\u66f4\u63a5\u8fd1\u81ea\u7136\u8bed\u8a00 \u3002  </p> <p>\u6ce8\uff1aC \u8bed\u8a00\u5e38\u88ab\u79f0\u4e3a\u201c\u4e2d\u7ea7\u8bed\u8a00\u201d\uff0c\u56e0\u4e3a\u5b83\u65e2\u6709\u9ad8\u7ea7\u8bed\u8a00\u7684\u7279\u6027\uff0c\u4e5f\u80fd\u76f4\u63a5\u64cd\u4f5c\u5185\u5b58\u6307\u9488 \u3002  </p> <p>\u6309\u7167\u53d1\u5c55\u7684\u987a\u5e8f\uff0c\u7f16\u7a0b\u8bed\u8a00\u662f\u4ece\u4f4e\u7ea7\u8bed\u8a00\u9010\u6b65\u6f14\u8fdb\u5230\u9ad8\u7ea7\u8bed\u8a00\u7684\uff0c\u6211\u4eec\u751a\u81f3\u53ef\u4ee5\u628a \"\u6c47\u7f16 \u2192 C \u8bed\u8a00 \u2192 C++ \u2192 Python\" \u770b\u6210\u4e00\u6761\u5b8c\u6574\u7684\u53d1\u5c55\u94fe\u6761 \ud83d\udd17\u3002</p>"},{"location":"python/#_1","title":"\ud83d\udca1 \u5b66\u4e60\u987a\u5e8f\u5efa\u8bae","text":"<p>\u90a3\u4e48\uff0c\u6211\u4eec\u662f\u5426\u8981\u4e25\u683c\u6309\u7167\u53d1\u5c55\u987a\u5e8f\u5b66\u4e60\u5462\uff1f\u663e\u7136\u4e0d\u592a\u5408\u7406\u3002\u6839\u636e\u6211\u7684\u7ecf\u9a8c\uff0c\u6700\u4f18\u5b66\u4e60\u987a\u5e8f\u662f\uff1a  </p> <p>C \u8bed\u8a00 \u2192 \u6c47\u7f16 \u2192 C++ \u2192 Python </p> <p>\u7406\u7531\uff1a\u6ca1\u6709 C \u8bed\u8a00\u57fa\u7840\u65f6\uff0c\u6c47\u7f16\u8bed\u8a00\u96be\u4ee5\u7406\u89e3\uff1bPython \u53ef\u4ee5\u770b\u4f5c\u662f C++ \u7684\u7b80\u5316\u7248\u672c \ud83d\udc0d\uff0c\u597d\u6bd4\u6570\u5b66\u4e2d\u7684\u4e8c\u7ea7\u7ed3\u8bba\uff0c\u56e0\u6b64\u5e94\u653e\u5728\u6700\u540e\u5b66\u4e60\u3002</p>"},{"location":"python/#2-python","title":"2\ufe0f\u20e3 \u4e3a\u4ec0\u4e48\u8981\u5b66\u4e60 Python \ud83e\udd14","text":"<p>\u5927\u591a\u6570\u9ad8\u6821\u5c06 Python \u4f5c\u4e3a\u5fc5\u4fee\u7f16\u7a0b\u8bed\u8a00\uff0c\u5f88\u591a\u4eba\u8ba4\u4e3a\u8fd9\u662f\u56e0\u4e3a Python \u7b80\u5355\u6613\u5b66\u4e14\u901a\u7528 \u3002  </p> <p>\u5b9e\u9645\u4e0a\uff0cPython \u5728\u5b9e\u9645\u5de5\u7a0b\u4e2d\u7684\u4f5c\u7528\u975e\u5e38\u5e7f\u6cdb\uff0c\u4e3b\u8981\u4f53\u73b0\u5728 \u7b80\u6d01\u6027\u3001\u53ef\u6269\u5c55\u6027\u548c\u4e30\u5bcc\u7684\u751f\u6001\u7cfb\u7edf \uff1a</p> <ul> <li>\ud83d\udcdd \u81ea\u52a8\u5316\u4e0e\u811a\u672c\u7f16\u5199\uff1a\u5feb\u901f\u5904\u7406\u6587\u4ef6\u64cd\u4f5c\u3001\u6570\u636e\u6e05\u6d17\u3001\u7cfb\u7edf\u8fd0\u7ef4\u7b49\uff0c\u5927\u5e45\u63d0\u9ad8\u5de5\u4f5c\u6548\u7387\u3002  </li> <li>\ud83d\udcca \u6570\u636e\u5904\u7406\u4e0e\u5206\u6790\uff1a\u7ed3\u5408 NumPy\u3001Pandas\u3001Matplotlib \u7b49\u5e93\uff0c\u9ad8\u6548\u8fdb\u884c\u6570\u503c\u8ba1\u7b97\u3001\u7edf\u8ba1\u5206\u6790\u548c\u53ef\u89c6\u5316\u3002  </li> <li>\ud83e\udd16 \u673a\u5668\u5b66\u4e60\u4e0e\u4eba\u5de5\u667a\u80fd\uff1aPython \u51e0\u4e4e\u662f\u6807\u51c6\u8bed\u8a00\uff0cTensorFlow\u3001PyTorch\u3001scikit-learn \u7b49\u5e93\u8ba9\u7b97\u6cd5\u5f00\u53d1\u548c\u6a21\u578b\u8bad\u7ec3\u66f4\u5feb\u901f\u3002  </li> <li>\ud83c\udf0d Web \u5f00\u53d1\u4e0e\u7cfb\u7edf\u96c6\u6210\uff1aDjango\u3001Flask \u7b49\u6846\u67b6\u53ef\u4ee5\u5feb\u901f\u642d\u5efa\u540e\u7aef\u670d\u52a1\uff0c\u5e76\u652f\u6301\u6570\u636e\u5e93\u4e0e API \u63a5\u53e3\u65e0\u7f1d\u5bf9\u63a5\u3002  </li> <li>\ud83d\udd2c \u79d1\u5b66\u8ba1\u7b97\u3001GIS \u5de5\u7a0b\u3001\u81ea\u52a8\u5316\u6d4b\u8bd5\u548c\u786c\u4ef6\u63a7\u5236\uff1a\u4f8b\u5982\u5728 GIS \u5de5\u7a0b\u4e2d\uff0c\u4f7f\u7528 ArcPy\u3001GeoPandas \u8fdb\u884c\u7a7a\u95f4\u5206\u6790\u548c\u5730\u56fe\u81ea\u52a8\u5316\u751f\u6210\u3002</li> </ul> <p>\u603b\u7684\u6765\u8bf4\uff0cPython \u4e0d\u4ec5\u662f\u5feb\u901f\u5f00\u53d1\u7684\u5229\u5668\uff0c\u4e5f\u662f\u4e00\u5ea7\u8fde\u63a5 \u6570\u636e\u3001\u7b97\u6cd5\u4e0e\u7cfb\u7edf \u7684\u9ad8\u6548\u6865\u6881 \u3002\u5176\u6613\u8bfb\u6027\u548c\u4e30\u5bcc\u5e93\u751f\u6001\u8ba9\u5de5\u7a0b\u9879\u76ee\u4ece\u539f\u578b\u5230\u751f\u4ea7\u90fd\u80fd\u5feb\u901f\u8fed\u4ee3 \u3002</p> <p>!!!  \u5b9e\u9645\u4e0a\uff0cPython \u66f4\u591a\u65f6\u5019\u662f \u627f\u8f7d\u5de5\u5177 \u7684\u5f62\u5f0f\u51fa\u73b0\u7684\u3002\u4f8b\u5982\uff0c\u5728\u8fd0\u884c\u4e00\u4e2a\u5927\u578b\u6a21\u578b\u65f6\uff0c\u6211\u4eec\u901a\u5e38\u901a\u8fc7 Python \u6765\u8c03\u7528\u5b83\uff0c\u5c31\u50cf\u4f7f\u7528\u7535\u8111\u5fc5\u987b\u901a\u8fc7\u9f20\u6807\u6216\u952e\u76d8\u4e00\u6837\u2014\u2014Python \u5c31\u662f\u6211\u4eec\u7684\u201c\u8c03\u7528\u624b\u6bb5\u201d\u3002</p>"},{"location":"tools/","title":"\u4e00\u4e9b\u5de5\u5177\u63a8\u8350","text":""},{"location":"tools/as_IDE/VS3/","title":"VS\u3001VS Code and VS Installer","text":"<p>\u5f15\u8a00\uff1a \u5173\u4e8e\u4e3a\u4ec0\u4e48\u8981\u4ecb\u7ecd VS Code\u2014\u2014\u6211\u76f8\u4fe1\u5927\u90e8\u5206\u4eba\u90fd\u77e5\u9053 VS Code \u6216\u8005\u542c\u8fc7\u5176\u5927\u540d\uff0c\u4f46\u5e38\u5e38\u5bf9\u4e8e VS\u3001VS Code\u3001VS Installer \u4e09\u8005\u7684\u5b9a\u4e49\u6a21\u7cca\u3002\u5e0c\u671b\u901a\u8fc7\u8fd9\u4e2a\u6587\u6863\uff0c\u4f60\u80fd\u5bf9\u4e09\u8005\u6709\u66f4\u6e05\u6670\u7684\u7406\u89e3 \ud83d\udca1\u3002</p>"},{"location":"tools/as_IDE/VS3/#1","title":"1\ufe0f\u20e3 \u80cc\u666f\u516c\u53f8\u4ecb\u7ecd \ud83c\udfe2","text":"<p>\u5fae\u8f6f\uff08Microsoft\uff09\uff1a\u5728\u65e9\u5e74\u95f4\uff0c\u5fae\u8f6f\u7684\u5de5\u5177\uff08\u5982 Visual Studio\uff09\u4e3b\u8981\u670d\u52a1\u4e8e Windows \u5e73\u53f0\u7684\u5f00\u53d1\u8005\u3002\u4f46\u81ea\u4ece \u8428\u63d0\u4e9a\u00b7\u7eb3\u5fb7\u62c9\uff08Satya Nadella\uff09 \u63a5\u4efb CEO \u540e\uff0c\u5fae\u8f6f\u7684\u7b56\u7565\u53d1\u751f\u5de8\u5927\u53d8\u5316\uff0c\u53e3\u53f7\u53d8\u6210\u4e86\u201c\u5fae\u8f6f\u7231\u5f00\u6e90\u201d \u3002</p> <p>VS Code \u662f\u8fd9\u4e00\u8f6c\u578b\u7684\u4ee3\u8868\u4f5c\u3002\u5fae\u8f6f\u610f\u8bc6\u5230\u5f00\u53d1\u8005\u4e0d\u518d\u53ea\u7528 Windows\uff0c\u5f88\u591a\u4eba\u5728 Mac \u6216 Linux \u4e0a\u5199\u4ee3\u7801 \u3002\u4e8e\u662f\u4ed6\u4eec\u57fa\u4e8e\u5f00\u6e90\u6280\u672f\uff08Electron\uff09\u6253\u9020\u4e86 VS Code\uff0c\u5e76\u5c06\u5176\u4ee3\u7801\u5728 GitHub \u4e0a\u5f00\u6e90 \u3002</p>"},{"location":"tools/as_IDE/VS3/#2","title":"2\ufe0f\u20e3 \u4ea7\u54c1\u57fa\u672c\u4ecb\u7ecd","text":""},{"location":"tools/as_IDE/VS3/#21-visual-studio-code-vs-code","title":"2.1 Visual Studio Code (VS Code) \ud83d\udcdd","text":"<p>\u5b9a\u4f4d\uff1a\u5f00\u6e90\u3001\u8de8\u5e73\u53f0\u7684 \u73b0\u4ee3\u5316\u4ee3\u7801\u7f16\u8f91\u5668\u3002  </p> <p>\u6838\u5fc3\u7279\u70b9\uff1a * \u26a1 \u8f7b\u91cf\u4e0e\u6781\u901f\uff1a\u542f\u52a8\u6781\u5feb\uff0c\u5185\u5b58\u5360\u7528\u4f4e  \ud83d\udd0c \u63d2\u4ef6\u5e93\u9f50\u5168\uff1a\u5b89\u88c5\u6269\u5c55\u5373\u53ef\u5b8c\u6210\u5404\u79cd\u8f7b\u91cf\u5f00\u53d1  \ud83c\udf0d \u8de8\u5e73\u53f0\uff1aWindows\u3001macOS \u548c Linux \u4e0a\u4f53\u9a8c\u4e00\u81f4  </p> <p>\ud83d\udca1 \u5bf9\u4e8e\u666e\u901a coding\uff0c\u6211\u4eec\u6700\u5e38\u7528\u7684\u5c31\u662f VS Code\u3002\u5173\u4e8e\u6211\u7684\u4f7f\u7528\u7ecf\u9a8c\uff0c\u53ef\u4ee5\u67e5\u770b\uff1aVScode\u5165\u95e8</p> <p></p>"},{"location":"tools/as_IDE/VS3/#22-visual-studio-vs","title":"2.2 Visual Studio (VS) \ud83c\udfd7\ufe0f","text":"<p>\u5b9a\u4f4d\uff1a\u88ab\u8a89\u4e3a\u201c\u5b87\u5b99\u7b2c\u4e00 IDE\u201d\u7684 \u5168\u529f\u80fd\u96c6\u6210\u5f00\u53d1\u73af\u5883 </p> <p>\u6838\u5fc3\u7279\u70b9\uff1a * \ud83c\udfcb\ufe0f \u91cd\u578b IDE\uff1a\u5185\u7f6e\u5f3a\u5927\u7f16\u8bd1\u5668\u3001\u8c03\u8bd5\u5668\u3001\u6027\u80fd\u5206\u6790\u5668\u548c\u56fe\u5f62\u5316\u754c\u9762\u8bbe\u8ba1\u5668  \ud83d\udd17 \u6df1\u5ea6\u96c6\u6210\uff1a\u5de5\u4e1a\u7ea7\u5bf9 .NET \u548c C++ \u652f\u6301\uff0c\u9002\u5408\u7ba1\u7406\u5927\u578b\u9879\u76ee  \ud83e\ude9f Windows \u539f\u751f\uff1a\u529f\u80fd\u6700\u5f3a\u59cb\u7ec8\u5728 Windows  \ud83c\udfaf \u9002\u7528\u573a\u666f*\uff1a\u5927\u578b Windows \u684c\u9762\u7a0b\u5e8f\u3001\u4e13\u4e1a\u6e38\u620f\u5f00\u53d1\uff08\u5982 Unreal Engine\uff09\u3001\u590d\u6742 C++ \u7b97\u6cd5\u7814\u7a76  </p> <p></p>"},{"location":"tools/as_IDE/VS3/#23-visual-studio-installer","title":"2.3 Visual Studio Installer \u2699\ufe0f","text":"<p>\u5b9a\u4f4d\uff1a\u7528\u4e8e\u5b89\u88c5\u3001\u7ba1\u7406\u548c\u4fee\u6539 Visual Studio \u7684\u5b98\u65b9\u5de5\u5177  </p> <p>\u4e3b\u8981\u529f\u80fd\uff1a * \ud83d\udce6 \u6309\u9700\u53d6\u7528\uff1a\u901a\u8fc7\u52fe\u9009\u201c\u5de5\u4f5c\u8d1f\u8f7d\u201d\u5b89\u88c5\u9700\u8981\u7684\u7ec4\u4ef6\uff0c\u8282\u7701\u78c1\u76d8\u7a7a\u95f4  \ud83d\udd04 \u4e00\u952e\u66f4\u65b0*\uff1a\u7ba1\u7406 VS \u7248\u672c\u5347\u7ea7\u548c\u4fee\u590d  </p> <p>!!!      \u5b83\u670d\u52a1\u4e8e Visual Studio\uff1b\u800cVS Code \u901a\u5e38\u72ec\u7acb\u5b89\u88c5\uff0c\u4e0d\u901a\u8fc7 Installer \u7ba1\u7406\u3002</p>"},{"location":"tools/as_IDE/VS3/#_1","title":"\ud83d\udd0d \u4e09\u8005\u5bf9\u6bd4","text":"\u7279\u6027 VS Code \ud83d\udcdd Visual Studio \ud83c\udfd7\ufe0f VS Installer \u2699\ufe0f \u5de5\u5177\u7c7b\u578b \u4ee3\u7801\u7f16\u8f91\u5668 \u96c6\u6210\u5f00\u53d1\u73af\u5883 (IDE) \u5b89\u88c5/\u7ba1\u7406\u5de5\u5177 \u8d44\u6e90\u5360\u7528 \u26a1 \u8f83\u4f4e \ud83c\udfcb\ufe0f \u8f83\u9ad8 \ud83e\ude84 \u6781\u4f4e \u4e0a\u624b\u96be\u5ea6 \ud83d\ude0a \u7b80\u5355\uff0c\u5373\u88c5\u5373\u7528 \u2699\ufe0f \u8f83\u590d\u6742\uff0c\u914d\u7f6e\u591a \ud83d\ude0a \u7b80\u5355 \u6838\u5fc3\u4f18\u52bf \ud83d\udd0c \u7075\u6d3b\u3001\u751f\u6001\u4e30\u5bcc \ud83c\udfc6 \u529f\u80fd\u5b8c\u5907\u3001\u8c03\u8bd5\u5f3a\u5927 \ud83d\udce6 \u6a21\u5757\u5316\u5b89\u88c5\u3001\u6613\u4e8e\u7ef4\u62a4"},{"location":"web_dev/","title":"\u5173\u4e8eweb\u5f00\u53d1","text":""}]}